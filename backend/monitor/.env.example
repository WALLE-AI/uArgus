# ── Redis (Upstash) ──────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# ── Agents Service (HTTP fallback when LLM_PROVIDER is empty) ─
AGENTS_URL=http://localhost:3001

# ── LLM Provider (direct, replaces AGENTS_URL when set) ──────
# Supported: anthropic | openai | ollama | vllm | openai_compat
LLM_PROVIDER=
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# ── Proxy ────────────────────────────────────────────────────
PROXY_RELAY_URL=
PROXY_CONNECT_URL=
PROXY_CURL_URL=

# ── Server ───────────────────────────────────────────────────
PORT=8090
ENV=development

# ── Feature Flags ────────────────────────────────────────────
SIDECAR_MODE=false
