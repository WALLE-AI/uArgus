# ── Redis (Upstash) ──────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# ── Agents Service ───────────────────────────────────────────
AGENTS_URL=http://localhost:3001

# ── Proxy ────────────────────────────────────────────────────
PROXY_RELAY_URL=
PROXY_CONNECT_URL=
PROXY_CURL_URL=

# ── Server ───────────────────────────────────────────────────
PORT=8090
ENV=development

# ── Feature Flags ────────────────────────────────────────────
SIDECAR_MODE=false
